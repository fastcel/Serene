<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set up your session"
            android:textColor="@color/text_color_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How long is your work session?"
            android:textColor="@color/text_color_blue"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/optWork25"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/chip_selected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="25 min"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optWork45"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="45 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optWork60"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="60 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What kind of break?"
            android:textColor="@color/text_color_blue"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/optBreakShort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chip_selected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="Short break"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optBreakLong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="Long break"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutShortOpts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/optShort5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/chip_selected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="5 min"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optShort10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="10 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optShort15"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="15 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutLongOpts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/optLong20"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="20 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optLong35"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="35 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/optLong50"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/pastel_blue"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="50 min"
                android:textColor="@color/text_color_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnStartSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_selected"
            android:backgroundTint="@color/pastel_blue"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:text="Start session"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/btnCancelSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_unselected"
            android:backgroundTint="@color/pastel_blue"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:text="Cancel"
            android:textColor="@color/text_color_blue"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>