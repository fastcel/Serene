<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvJournalTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Journals"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="10dp" />

        <!-- EMPTY STATE -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="120dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No journals yet 📝"
                android:textSize="18sp"
                android:textColor="#444" />

            <Button
                android:id="@+id/btnStartWriting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Write your first journal"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/btnViewFavorites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★ View Favorites"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#6058B0"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerJournals"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

    <!-- BIGGER FAB -->
    <ImageButton
        android:id="@+id/fabAddJournal"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/addicon"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:contentDescription="Add Journal"/>

</FrameLayout>