<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Goal"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A4A"
        android:layout_marginBottom="16dp"/>

    <!-- ── GOAL TITLE ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Goal"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#3A3A7A"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="What do you want to achieve?"
        android:textSize="13sp"
        android:textColor="#1A1A4A"
        android:textColorHint="#9A9ACA"
        android:background="@drawable/chip_unselected"
        android:backgroundTint="#E8EAFA"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:inputType="textCapSentences"
        android:layout_marginBottom="14dp"/>


    <!-- ── DUE DATE ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Due date"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#3A3A7A"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📅 Select due date"
        android:textSize="13sp"
        android:textColor="#6058B0"
        android:background="@drawable/chip_unselected"
        android:backgroundTint="#E8EAFA"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="16dp"/>

    <!-- ── DUE TIME ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Due time"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#3A3A7A"
        android:layout_marginBottom="6dp"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏰ Select time"
        android:textSize="13sp"
        android:textColor="#6058B0"
        android:background="@drawable/chip_unselected"
        android:backgroundTint="#E8EAFA"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="16dp"/>
    <!-- ── PRIORITY ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Priority"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#3A3A7A"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/priorityLow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Low"
            android:textSize="12sp"
            android:textColor="#2A5A34"
            android:gravity="center"
            android:background="@drawable/chip_unselected"
            android:backgroundTint="#C8E8D0"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/priorityMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Medium"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/chip_selected"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/priorityHigh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="High"
            android:textSize="12sp"
            android:textColor="#803040"
            android:gravity="center"
            android:background="@drawable/chip_unselected"
            android:backgroundTint="#F0C8D0"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ── BUTTONS ROW ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textSize="13sp"
            android:textColor="#6A6AAA"
            android:gravity="center"
            android:background="@drawable/chip_unselected"
            android:backgroundTint="#CDD4F0"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSaveGoal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save Goal"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@color/light_purple"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>