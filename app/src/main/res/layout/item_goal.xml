<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/card_bg"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">

    <View
        android:id="@+id/viewAccent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#6058B0"
        android:layout_marginEnd="12dp"
        android:minHeight="48dp"/>

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/checkGoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"/>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvGoalTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A4A"
            android:layout_marginBottom="3dp"/>

        <!-- DATE -->
        <TextView
            android:id="@+id/tvGoalDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 05/05/2026"
            android:textSize="13sp"
            android:textColor="#6A6AAA"
            android:layout_marginBottom="2dp"/>

        <!-- TIME -->
        <TextView
            android:id="@+id/tvGoalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰ 18:00"
            android:textSize="12sp"
            android:textColor="#9A9ACA"/>
    </LinearLayout>

    <!-- RIGHT SIDE BADGES -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Priority badge -->
        <TextView
            android:id="@+id/tvPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/chip_selected"/>

        <!-- Overdue badge -->
        <TextView
            android:id="@+id/tvOverdueBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overdue"
            android:textSize="14sp"
            android:textColor="#803040"
            android:background="@drawable/chip_unselected"
            android:backgroundTint="#F0C8D0"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>