<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/introslide1"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- TOP TEXT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Express Yourself"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_color_blue"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Write your thoughts freely and track your emotional journey every day."
            android:textSize="20sp"
            android:textColor="@color/text_color_blue"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- CENTER IMAGE -->
    <ImageView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:src="@drawable/journal"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:layout_marginTop="30dp"/>

    <!-- BUTTON -->
    <Button
        android:id="@+id/btnStartNow"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Start Now"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/pastel_blue"
        android:layout_marginTop="20dp"/>

</LinearLayout>