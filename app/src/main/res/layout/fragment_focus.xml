<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp"
            android:text="Focus"
            android:textColor="@color/text_color_purple"
            android:textSize="30sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="70dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/circle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Work Session"
                    android:textColor="@color/text_color_purple"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:letterSpacing="0.05"
                    android:text="25:00"
                    android:textColor="@color/text_color_purple"
                    android:textSize="52sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnReset"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/text_color_purple"
                android:gravity="center"
                android:text="↺"
                android:textColor="@color/black"
                android:textSize="22sp" />

            <ImageView
                android:id="@+id/btnPlayPause"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:src="@drawable/play"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/btnSkip"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/chip_unselected"
                android:backgroundTint="@color/text_color_purple"
                android:gravity="center"
                android:text="⏭"
                android:textColor="@color/black"
                android:textSize="22sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/chip_unselected"
            android:backgroundTint="@color/text_color_purple"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT SESSION"
                        android:textColor="@color/text_color_purple"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvSessionSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="No session started"
                        android:textColor="@color/text_color_purple"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btnNewSession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_selected"
                    android:backgroundTint="@color/purple"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="New session"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>