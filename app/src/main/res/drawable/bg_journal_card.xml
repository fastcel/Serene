<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background fill -->
    <solid android:color="@color/light_purple"/>

    <!-- Dark outline -->
    <stroke
        android:width="2dp"
        android:color="#2F3A8F" />

    <!-- Rounded corners -->
    <corners android:radius="16dp"/>

    <!-- Optional padding feel inside card -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"/>
</shape>